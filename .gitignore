# Generated by DevMind setup wizard. Customize as needed.

# Secrets — never commit
.env
.env.*
!.env.example
*.key
*.pem
*.p12
credentials.json
service-account.json

# DevMind workflow + session state — should never be in your repo.
# CLAUDE.md is the phase-tracking instruction file DevMind writes
# locally; users frequently paste tokens / credentials into it as
# notes, which is exactly how PATs end up leaking on push. Keeping
# it gitignored makes that whole class of leak impossible.
CLAUDE.md
.devmind/

